{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Machine-readable capability matrix for all supported AI coding assistant ecosystems. Used by the validator's COV-* rules and the generator's degradation annotations.",
  "version": "1.0.0",
  "ecosystems": {
    "claude-code": {
      "id": "claude-code",
      "name": "Claude Code",
      "vendor": "Anthropic",
      "config_files": ["CLAUDE.md", "AGENTS.md", ".claude/settings.json", ".claude/skills/*.md"],
      "capabilities": {
        "always_on_instructions": { "supported": true, "mechanism": "CLAUDE.md root file, always loaded" },
        "file_glob_scoped_rules": { "supported": true, "mechanism": "Nested CLAUDE.md files per directory, @import syntax" },
        "directory_scoped_rules": { "supported": true, "mechanism": "Subdirectory CLAUDE.md files cascade" },
        "tool_permissions_allow": { "supported": true, "mechanism": "settings.json permissions.allow array with ToolName(glob) patterns" },
        "tool_permissions_deny": { "supported": true, "mechanism": "settings.json permissions.deny array" },
        "lifecycle_hooks": { "supported": true, "mechanism": "settings.json hooks array — PreToolUse, PostToolUse, UserPromptSubmit, Notification, Stop" },
        "sub_agents": { "supported": true, "mechanism": "AGENTS.md + Task tool for orchestration" },
        "skill_system": { "supported": true, "mechanism": "Claude Code Skill tool — .md files with YAML frontmatter" },
        "memory_always_load": { "supported": true, "mechanism": "CLAUDE.md @import directives" },
        "memory_on_demand": { "supported": true, "mechanism": "Skills and memory files loaded via tool" },
        "ignore_patterns": { "supported": true, "mechanism": ".gitignore semantics, also .claude/ignore" },
        "environment_variables": { "supported": true, "mechanism": "settings.json env block" },
        "model_selection": { "supported": true, "mechanism": "settings.json model field" },
        "multi_file_rules": { "supported": true, "mechanism": "Hierarchical CLAUDE.md cascade + skill files" },
        "rule_prioritization": { "supported": true, "mechanism": "Cascade order; @import ordering; skills ranked by description match" },
        "markdown_in_rules": { "supported": true, "mechanism": "Full markdown in CLAUDE.md and skill files" },
        "code_examples_in_rules": { "supported": true, "mechanism": "Fenced code blocks in CLAUDE.md" }
      },
      "uir_field_fidelity": {
        "meta": "full",
        "context": "full",
        "rules": "full",
        "permissions": "full",
        "memory": "full",
        "hooks": "full",
        "skills": "full",
        "agents": "full",
        "ignore_patterns": "full",
        "extensions": "full"
      }
    },

    "cursor": {
      "id": "cursor",
      "name": "Cursor",
      "vendor": "Anysphere",
      "config_files": [".cursor/rules/*.mdc", ".cursorignore"],
      "capabilities": {
        "always_on_instructions": { "supported": true, "mechanism": ".mdc files with alwaysApply: true" },
        "file_glob_scoped_rules": { "supported": true, "mechanism": ".mdc files with globs: field (picomatch syntax)" },
        "directory_scoped_rules": { "supported": "partial", "mechanism": "Via glob patterns pointing to directory paths" },
        "tool_permissions_allow": { "supported": false, "degradation": "Converted to 'always do X' rule text — no enforcement" },
        "tool_permissions_deny": { "supported": false, "degradation": "Converted to 'never do X' rule text — no enforcement" },
        "lifecycle_hooks": { "supported": false, "degradation": "Converted to 'before/after X always...' rule text — not executed" },
        "sub_agents": { "supported": false, "degradation": "Flattened to context section in index.mdc" },
        "skill_system": { "supported": "partial", "mechanism": "Manual-activation .mdc files referenced with @filename — not a structured skill system" },
        "memory_always_load": { "supported": true, "mechanism": "alwaysApply: true .mdc files" },
        "memory_on_demand": { "supported": "partial", "mechanism": ".mdc files with alwaysApply: false, manually referenced" },
        "ignore_patterns": { "supported": true, "mechanism": ".cursorignore file (gitignore syntax)" },
        "environment_variables": { "supported": false, "degradation": "Not supported — dropped during generation" },
        "model_selection": { "supported": true, "mechanism": "Cursor UI settings or .cursor/settings.json" },
        "multi_file_rules": { "supported": true, "mechanism": "Multiple .mdc files in .cursor/rules/" },
        "rule_prioritization": { "supported": "partial", "mechanism": "alwaysApply boolean only — no numeric priority" },
        "markdown_in_rules": { "supported": true, "mechanism": "Full markdown in .mdc body" },
        "code_examples_in_rules": { "supported": true, "mechanism": "Fenced code blocks in .mdc body" }
      },
      "uir_field_fidelity": {
        "meta": "none",
        "context": "full",
        "rules": "full",
        "permissions": "degraded — converted to rule text, no enforcement",
        "memory": "partial — always_load supported; on_demand is manual-only",
        "hooks": "degraded — converted to rule text, not executed",
        "skills": "partial — manual .mdc files, no structured activation",
        "agents": "degraded — flattened to context section",
        "ignore_patterns": "full — .cursorignore",
        "extensions": "partial — cursor extension block respected"
      }
    },

    "codex": {
      "id": "codex",
      "name": "OpenAI Codex CLI",
      "vendor": "OpenAI",
      "config_files": ["AGENTS.md", "system-prompt.txt"],
      "capabilities": {
        "always_on_instructions": { "supported": true, "mechanism": "AGENTS.md global instructions section" },
        "file_glob_scoped_rules": { "supported": false, "degradation": "Flattened to global rules with scope annotation text" },
        "directory_scoped_rules": { "supported": false, "degradation": "Flattened to global rules" },
        "tool_permissions_allow": { "supported": false, "degradation": "Converted to rule text" },
        "tool_permissions_deny": { "supported": false, "degradation": "Converted to rule text" },
        "lifecycle_hooks": { "supported": false, "degradation": "Not translatable — dropped with CROSS-SKILLS: NOT TRANSLATABLE annotation" },
        "sub_agents": { "supported": true, "mechanism": "AGENTS.md ## AgentName sections — OpenAI native format" },
        "skill_system": { "supported": false, "degradation": "Converted to task description sections in AGENTS.md" },
        "memory_always_load": { "supported": "partial", "mechanism": "AGENTS.md Context section — single block, no lazy loading" },
        "memory_on_demand": { "supported": false, "degradation": "Not supported" },
        "ignore_patterns": { "supported": false, "degradation": "Not supported in Codex CLI" },
        "environment_variables": { "supported": false, "degradation": "Not supported" },
        "model_selection": { "supported": true, "mechanism": "CLI flags (--model)" },
        "multi_file_rules": { "supported": false, "degradation": "Single AGENTS.md file only" },
        "rule_prioritization": { "supported": "partial", "mechanism": "Ordering within AGENTS.md — first instructions have higher precedence" },
        "markdown_in_rules": { "supported": true, "mechanism": "Markdown in AGENTS.md body" },
        "code_examples_in_rules": { "supported": true, "mechanism": "Fenced code blocks in AGENTS.md" }
      },
      "uir_field_fidelity": {
        "meta": "none",
        "context": "full",
        "rules": "partial — global only; file-glob scoping lost",
        "permissions": "degraded — converted to rule text, no enforcement",
        "memory": "partial — single always-on context block; no on-demand",
        "hooks": "none — dropped",
        "skills": "degraded — task descriptions only",
        "agents": "full — native AGENTS.md format",
        "ignore_patterns": "none",
        "extensions": "partial — codex extension block respected"
      }
    },

    "aider": {
      "id": "aider",
      "name": "Aider",
      "vendor": "Paul Gauthier / aider.chat",
      "config_files": [".aider.conf.yml", "CONVENTIONS.md", ".aiderignore"],
      "capabilities": {
        "always_on_instructions": { "supported": true, "mechanism": "CONVENTIONS.md read via .aider.conf.yml read: field" },
        "file_glob_scoped_rules": { "supported": false, "degradation": "Flattened — scope noted as text annotation" },
        "directory_scoped_rules": { "supported": false, "degradation": "Flattened" },
        "tool_permissions_allow": { "supported": false, "degradation": "Converted to convention text" },
        "tool_permissions_deny": { "supported": false, "degradation": "Converted to 'Never run: X' convention text" },
        "lifecycle_hooks": { "supported": false, "degradation": "Not translatable — dropped" },
        "sub_agents": { "supported": false, "degradation": "Flattened to named sections in CONVENTIONS.md" },
        "skill_system": { "supported": false, "degradation": "Converted to named ## Skill sections in CONVENTIONS.md" },
        "memory_always_load": { "supported": true, "mechanism": ".aider.conf.yml read: list — loaded every session" },
        "memory_on_demand": { "supported": "partial", "mechanism": "User can /add files in chat; not auto-managed" },
        "ignore_patterns": { "supported": true, "mechanism": ".aiderignore file (gitignore syntax)" },
        "environment_variables": { "supported": true, "mechanism": "--env-file flag pointing to .env file" },
        "model_selection": { "supported": true, "mechanism": ".aider.conf.yml model: field or --model flag" },
        "multi_file_rules": { "supported": false, "degradation": "Single CONVENTIONS.md; multiple read: files possible but no scoping" },
        "rule_prioritization": { "supported": "partial", "mechanism": "Order within CONVENTIONS.md — earlier sections have higher precedence" },
        "markdown_in_rules": { "supported": true, "mechanism": "Full markdown in CONVENTIONS.md" },
        "code_examples_in_rules": { "supported": true, "mechanism": "Fenced code blocks in CONVENTIONS.md" }
      },
      "uir_field_fidelity": {
        "meta": "none",
        "context": "full — CONVENTIONS.md overview section",
        "rules": "partial — global only; file-glob scoping lost",
        "permissions": "degraded — converted to convention text",
        "memory": "partial — always_load via read:; on_demand is manual /add",
        "hooks": "none — dropped",
        "skills": "degraded — named sections in CONVENTIONS.md",
        "agents": "degraded — flattened to CONVENTIONS.md sections",
        "ignore_patterns": "full — .aiderignore",
        "extensions": "partial — aider extension block respected"
      }
    }
